DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=multi_auth

JWT_SECRET=change-me-please
JWT_EXP_HORAS=8

# reCAPTCHA v2 (checkbox "No soy un robot")
# Site key publica la pone el frontend; secret va aca para validar el token contra Google.
# Generarlas en https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET=change-me-please

# Si esta en true, el endpoint /captcha-test responde igual sin validar (util para tests automatizados).
# NO usar en produccion.
RECAPTCHA_DISABLED=false
